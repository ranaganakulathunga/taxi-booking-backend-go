# Taxi Booking Backend - Environment Configuration

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/taxi_booking?sslmode=disable

# Server
PORT=8080
GIN_MODE=debug

# Optional: JWT secret for authentication (future use)
# JWT_SECRET=your_secret_key_here

# Optional: AWS or storage config (future use)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
